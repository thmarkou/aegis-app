{
  "expo": {
    "jsEngine": "jsc",
    "name": "AEGIS",
    "slug": "aegis-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icons/aegis.png",
    "scheme": "aegis",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/icons/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.aegis.survival",
      "disableNotifications": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icons/aegis.png",
        "backgroundColor": "#000000"
      },
      "package": "app.aegis.survival"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icons/splash.png",
          "backgroundColor": "#000000",
          "imageWidth": 280
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "AEGIS needs location for APRS beacon packets.",
          "locationAlwaysAndWhenInUsePermission": "AEGIS needs location for APRS beacon packets."
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "AEGIS uses step count for DIST_WALKED telemetry on the tactical dashboard."
        }
      ],
      "./plugins/withHealthKit.js",
      "./plugins/withMicrophone.js",
      "./plugins/withWatermelonDBSimdjson.js",
      "./plugins/withoutPushForPersonalTeam.js"
    ]
  }
}
