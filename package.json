{
  "name": "aegis-app",
  "version": "0.1.0",
  "private": true,
  "description": "AEGIS – Digital Survival OS. Offline-first Mission Control for Prepping, Ham Radio & Wearables.",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "ios:release": "expo run:ios --configuration Release",
    "android": "expo run:android",
    "web": "expo start --web",
    "prebuild:ios": "expo prebuild --platform ios && node scripts/remove-push-entitlement.js",
    "prebuild:android": "expo prebuild --platform android",
    "generate:notification-icon": "node scripts/generate-notification-icon.js",
    "generate:splash": "node scripts/generate-splash-images.js",
    "make:transparent": "node scripts/make-images-transparent.js",
    "update:images": "npm run generate:splash"
  },
  "dependencies": {
    "@nozbe/watermelondb": "^0.27.1",
    "@nozbe/with-observables": "^1.6.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/datetimepicker": "^8.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "buffer": "^6.0.3",
    "expo": "~52.0.0",
    "expo-asset": "~10.0.0",
    "expo-av": "~15.0.2",
    "expo-battery": "~8.0.0",
    "expo-camera": "~16.0.18",
    "expo-constants": "~17.0.0",
    "expo-file-system": "~18.0.0",
    "expo-font": "~13.0.0",
    "expo-haptics": "~14.0.1",
    "expo-local-authentication": "~15.0.0",
    "expo-location": "~18.0.10",
    "expo-notifications": "~0.29.0",
    "expo-secure-store": "~14.0.1",
    "expo-sensors": "~14.0.1",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.0",
    "nativewind": "^4.2.2",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-get-random-values": "1.11.0",
    "react-native-health": "^1.19.0",
    "react-native-maps": "^1.20.1",
    "react-native-microphone-stream": "^1.0.3",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "^15.8.0",
    "tailwindcss": "^3.4.17",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/plugin-proposal-decorators": "^7.25.0",
    "@types/react": "~18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.0",
    "sharp": "^0.34.5",
    "typescript": "~5.3.0"
  },
  "engines": {
    "node": ">=20"
  }
}
